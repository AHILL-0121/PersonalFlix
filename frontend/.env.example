# ─── Clerk ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Paste the full JSON of your service-account key here (as a single-line string)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# The root folder ID of your Shared Drive "MAIN" folder
DRIVE_ROOT_FOLDER_ID=REPLACE_ME

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── Transcoder (Optional) ───────────────────────────────────────────────────
# If set, FFmpeg stream remuxing and track detection will be offloaded to this URL
TRANSCODER_URL=https://your-transcoder-url.onrender.com
